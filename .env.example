# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
APP_BASE_URL=https://your-domain.com    # Public URL Twilio will POST webhooks to
APP_PORT=8000
DEBUG=false

# -----------------------------------------------------------------------
# Twilio
# -----------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567        # Your Twilio number in E.164 format

# -----------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------
# Deepgram (STT)
# -----------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key

# -----------------------------------------------------------------------
# LiveKit (self-hosted on AWS EC2)
# -----------------------------------------------------------------------
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# -----------------------------------------------------------------------
# Pinecone
# -----------------------------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=hvac-knowledge-base

# -----------------------------------------------------------------------
# PostgreSQL (AWS RDS)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hvac_agent

# -----------------------------------------------------------------------
# Redis (AWS ElastiCache)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------
# Admin API
# -----------------------------------------------------------------------
ADMIN_API_KEY=your_secure_admin_api_key
