# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
APP_BASE_URL=https://your-domain.com
APP_PORT=8000
DEBUG=false

# -----------------------------------------------------------------------
# Twilio
# -----------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18005551234
TRANSFER_PHONE_NUMBER=+18001234567

# -----------------------------------------------------------------------
# Linq (SMS)
# Register a webhook subscription at https://dashboard.linqapp.com pointing
# to: https://your-domain.com/linq/webhook  (event: message.received)
# The signing secret is returned once when you create the subscription.
# -----------------------------------------------------------------------
LINQ_API_TOKEN=your_token_here
LINQ_FROM_NUMBER=+15551234567
LINQ_WEBHOOK_SECRET=your_signing_secret_here

# -----------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------
# Deepgram (STT)
# -----------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key

# -----------------------------------------------------------------------
# LiveKit
# -----------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# LiveKit SIP host — used to build the <Dial><Sip> TwiML URI
# LiveKit Cloud:   find on Project Settings page, e.g. "xyz.sip.livekit.cloud"
# Self-hosted:     hostname or IP of your LiveKit SIP server
LIVEKIT_SIP_HOST=xyz.sip.livekit.cloud

# SIP trunk credentials — must match what you set with `lk sip inbound create`
SIP_TRUNK_USERNAME=your_sip_username
SIP_TRUNK_PASSWORD=your_sip_password

# -----------------------------------------------------------------------
# Gmail
# -----------------------------------------------------------------------
GMAIL_SENDER=first.last@domain.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx 

# -----------------------------------------------------------------------
# Pinecone
# -----------------------------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=hvac-knowledge-base
PINECONE_GEO_INDEX_NAME=hvac-geo-directory

# -----------------------------------------------------------------------
# PostgreSQL (AWS RDS)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hvac_agent

# -----------------------------------------------------------------------
# Redis (AWS ElastiCache)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------
# Admin API
# -----------------------------------------------------------------------
ADMIN_API_KEY=your_secure_admin_api_key
